# Copy to .env and tweak as needed.
XINCHAO_HOST=127.0.0.1
XINCHAO_PORT=8000

# WhisperX
XINCHAO_WHISPER_DEVICE=cpu          # cuda if you have an NVIDIA GPU
XINCHAO_WHISPER_COMPUTE_TYPE=int8   # float16 on GPU, int8 on CPU
XINCHAO_WHISPER_MODEL=small         # tiny|base|small|medium|large-v3|large-v3-turbo

# ── Caption translation (LLM) ───────────────────────────────────────────────
# Fill in ONE key (whichever provider you have). Endpoint URLs are built in —
# you only need the key. If several are set, priority is:
#   Gemini → OpenAI → Anthropic → OpenRouter.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# OpenRouter API base (code appends /chat/completions). Override for a proxy.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional model override per provider (defaults are cheap & fast):
#   gemini → gemini-2.0-flash | openai → gpt-4o-mini
#   anthropic → claude-3-5-haiku-latest | openrouter → google/gemini-2.0-flash-001
# OPENROUTER_TRANSLATE_MODEL=google/gemini-2.0-flash-001
