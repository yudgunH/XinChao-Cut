# Copy this file to backend/.env for manual development.
# Settings fields use the XINCHAO_ prefix. Hosted LLM keys are unprefixed.

# Server
XINCHAO_HOST=127.0.0.1
XINCHAO_PORT=8000
XINCHAO_WORK_DIR=./.work

# Export/cache
XINCHAO_EXPORT_THREADS=0
XINCHAO_EXPORT_CHUNK_PARALLELISM=0
XINCHAO_EXPORT_CHUNK_CACHE_MB=12000
XINCHAO_EXPORT_CHUNK_CACHE_TTL_DAYS=14
XINCHAO_EXPORT_CHUNK_CACHE_SEGMENT_SEC=300
XINCHAO_ASSETS_QUOTA_MB=5000
XINCHAO_ASSETS_TTL_DAYS=30
XINCHAO_JOBS_QUOTA_MB=8000
XINCHAO_JOBS_TTL_DAYS=7

# WhisperX: auto chooses CUDA when a compatible GPU/runtime is available.
XINCHAO_WHISPER_DEVICE=auto
XINCHAO_WHISPER_COMPUTE_TYPE=auto
XINCHAO_WHISPER_MODEL=small
XINCHAO_WHISPER_CACHE=models

# Optional local AI cache/runtime overrides
XINCHAO_FUNASR_CACHE=modelscope
XINCHAO_TTS_HF_HOME=hf-cache
XINCHAO_TTS_VOICES_DIR=voices
# XINCHAO_OMNIVOICE_PYTHON=G:\path\to\.venv-omnivoice\Scripts\python.exe

# Optional automatic speaker diarization (Hugging Face gated models).
PYANNOTE_TOKEN=

# Optional hosted subtitle translation. Fill only the provider(s) you use.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional per-provider model overrides:
# GEMINI_TRANSLATE_MODEL=
# OPENAI_TRANSLATE_MODEL=
# ANTHROPIC_TRANSLATE_MODEL=
# OPENROUTER_TRANSLATE_MODEL=
